---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const { title = 'Hi 👋 | Blog by Chetan Raj' } = Astro.props;
---

<header class="mb-6 border-b border-gray-200 py-4">
  <nav class="flex items-baseline justify-between gap-4">
    <a href={base} class="text-lg font-semibold hover:text-gray-700">
      {title}
    </a>
    <div class="flex gap-3 text-sm">
      <a href={base} class="text-gray-700 hover:text-blog-primary hover:underline">Home</a>
        <a href={`${base}posts/`} class="text-gray-700 hover:text-blog-primary hover:underline">Posts</a>
      </div>
  </nav>
</header>

