---
const { title = 'Blog' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
