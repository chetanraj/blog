---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
export const prerender = true;
export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props as { post: CollectionEntry<'posts'> };
const { Content } = await render(post);
---
<BaseLayout title={post.data.title} headerTitle={post.data.title}>
  <article class="blog-post-container blog-post-content">
    <p class="text-sm text-blog-secondary mb-6">
      {post.data.date.toISOString().slice(0, 10)}
    </p>
    <Content />
  </article>
</BaseLayout>
